# 使用前先复制为 .env：
# cp .env.example .env

# 必填：阿里云 DashScope API Key。
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# 必填：JWT 签名密钥，生产环境请替换为 32 位以上随机字符串。
JWT_SECRET=replace-with-at-least-32-random-characters

# MySQL 容器账号密码。
MYSQL_ROOT_PASSWORD=replace-root-password
MYSQL_USER=enterprise
MYSQL_PASSWORD=replace-db-password

# 宿主机端口映射。
FRONTEND_PORT=80
BACKEND_PORT=8123
MYSQL_PORT=3306
